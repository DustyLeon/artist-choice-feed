# Paste these into Railway → your project → Variables tab
# Never commit actual values to GitHub

DISCORD_TOKEN=          # Bot token from Discord Developer Portal
LASTFM_API_KEY=         # From https://www.last.fm/api/account/create
LASTFM_SECRET=          # From same page (optional but recommended)
YOUTUBE_API_KEY=        # From Google Cloud Console → YouTube Data API v3
FEED_CHANNEL_ID=        # Right-click your #community-artist-choice-feed channel → Copy ID
                        # (requires Developer Mode on in Discord settings)
DB_PATH=/data/artists.db  # Leave as-is if using Railway persistent volume
